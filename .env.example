# ===========================================================================
# holo-platform — environment template (S28)
# Copy to .env.local for local dev; set these in Vercel for prod/staging.
# NEVER commit real secrets. .env / .env.local are gitignored; this file is not.
# ===========================================================================

# --- Environment ----------------------------------------------------------
HOLO_ENV=development            # development | staging | production

# --- Database (HOLO Core, server-side only) --------------------------------
# Supabase Postgres connection string. Core talks to Postgres directly (pg).
# In Supabase: Project Settings → Database → Connection string (URI).
# Use the pooled connection for serverless (Vercel). SERVER-SIDE ONLY.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres

# Supabase project handles (for future Supabase JS / Storage use).
# SUPABASE_SERVICE_ROLE_KEY is SERVER-SIDE ONLY — never expose to the client.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Agent runner ----------------------------------------------------------
AGENT_MODE=mock                 # mock (default) | live
ANTHROPIC_API_KEY=              # required only when AGENT_MODE=live
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_API_KEY=                 # reserved for the model router (not used in v1)

# --- Payments (gated by the flag; off = free beta, everything open) --------
PAYMENTS_ENABLED=false          # true | false
STRIPE_SECRET_KEY=              # required only when PAYMENTS_ENABLED=true (live)
STRIPE_WEBHOOK_SECRET=          # required to verify the Stripe webhook signature
APP_URL=http://localhost:3000   # base URL for Stripe success/cancel redirects

# --- Client (exposed to the browser — NO secrets) --------------------------
# Empty = Core is same-origin (v1). Set to the Core service URL after extraction.
NEXT_PUBLIC_HOLO_CORE_URL=
